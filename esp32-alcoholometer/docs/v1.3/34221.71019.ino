   lcd.begin(16, 2);
   lcd.print("noMo\5Huk npu");
   lcd.setCursor(0, 1);
   lcd.print("DucTu\6\6\7\4uu");
   lcd.setCursor(12, 1);
   lcd.print(V);
   delay(3000);
   // Экран при загрузке с информацией о давлении и поправке температуры 8 сек
   lcd.clear();
   lcd.print("P:");
   lcd.print(Pr,0);
   lcd.print("mm dP:");
   lcd.print(dP,0);
   lcd.print("mm");
   lcd.setCursor(0, 1);
   lcd.print("T:");
   lcd.print(Tp,1);
   lcd.print("\1 dT:");
   lcd.print(dT,2);
   lcd.print("\1");
   delay(8000);
