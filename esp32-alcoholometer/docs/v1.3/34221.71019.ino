 void setup() 
 {
   Serial.begin(9600);
   pinMode(9, OUTPUT);                        // 9 пин отвечает за яркость информации 
   analogWrite(9, 100);                       // на дисплее, можно установить свою вместо 100
   sensors.begin();
   // Устанавливаем точность измерения термометров в 0,0625*С, отображение на дисплее все равно ведется с округлением до десятых, а в расчетах эта точность
   sensors.setResolution(Thermometer1, 12);
   sensors.setResolution(Thermometer2, 12);
   Wire.begin();
   dps.init(MODE_ULTRA_HIGHRES, 0, true); 
   dps.getPressure(&Pressure);                // Читаем давление с датчика давления
   dps.getTemperature(&Temperature);          // Читаем температуру с датчика давления
   Pr=Pressure/133.3;                         // Переводим давление из паскалей в мм рт ст
   dP=Pr-760;                                 // Расчитываем разницу давлений между нормой 760 мм и текущим
   dT=0.035*dP;                               // Расчитываем поправку к температуре исходя из давления
   Tp=Temperature*0.1;                        // Температура в помещении
   lcd.createChar(1, gradus);
   lcd.createChar(4, C);
   lcd.createChar(5, sch);
   lcd.createChar(6, L);
   lcd.createChar(7, Ya);
