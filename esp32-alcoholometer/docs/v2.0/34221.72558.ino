  EEPROM.write(4, TS);
  EEFW(8, Tstop);
  EEFW(12, dTD78_81);
  EEFW(16, dTD81_84);
  EEFW(20, dTD84_87);
  EEFW(24, dTD87_90);
  EEFW(28, dTD90_91);
  EEFW(32, dTD91_92);
  EEFW(36, dTD92_93);
  EEFW(40, dTD93_94);
  EEFW(44, dTD94_95);
  EEFW(48, dTD95_96);
  EEFW(52, dTD96_97);
  EEFW(56, dTD97_98);
  EEFW(60, dTD98_99);
  EEFW(64, dTD99_100);
  EEPROM.write(68, Kstop);
  EEPROM.write(69, E);
  EEPROM.write(70, W);
  EEPROM.write(71, A);
 }
       
//Процедура редактирования параметров 1
  void edit1()
   {
    if(Y < 400)
     {
      dT0=dT0+d;
      if(dT0 >= Tmax)
       {
        dT0=Tmax;
        }
       }
        if(Y > 600)
         {
          dT0=dT0-d;
          if(dT0 <= Tmin)
           {
            dT0=Tmin;
            }
           }
        }
        
//Процедура редактирования параметров 2
  void edit2()
   {
    if(Y < 400)
     {
      dT0=dT0+d;
      if(dT0 >= dTDmax)
       {
        dT0=dTDmax;
        }
       }
        if(Y > 600)
         {
          dT0=dT0-d;
          if(dT0 <= dTDmin)
           {
            dT0=dTDmin;
            }
           }
        }
        
