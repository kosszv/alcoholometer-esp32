//Процедура отсчета времени для выхода на основной экран в случае бездействия
 void exit()
 { 
  if(Q==0)
   {
    Q=1;
    time=millis();
    }
  if(X>400 && X<600 && Y>400 && Y<600 && Z==0 && R==0)
   {
    if(millis()-time>10000)
     {
      S=1;
      Q=0; 
      M=0;
      P=1;
     }
    }
   else
    {
     time=millis();
    }
  }
 void nosound()
  {
    if(Q2==0 && F!=2)
     {
       Q2=1;
       time2=millis();
     }
    if(F==1)
     {
      if(millis()-time2>TS*1000)
       {
        F=2;
        Q2=0;
        if (P1==0)
         {
          B=1;
          P1=1;
         }
       }
     }
    else
     {
      time2=millis();
     }
  } 
//Процедура записи параметров в еепром
 void eeprom()
 {
