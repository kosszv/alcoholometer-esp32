 sensors.begin();
 sensors.getAddress(kub, 0); 
 sensors.getAddress(distil, 1) ;
 sensors.setResolution(kub, 12);
 sensors.setResolution(distil, 12);
 // Заставка с названием программы и номером версии 3 сек
 lcd.init();
 lcd.backlight();
