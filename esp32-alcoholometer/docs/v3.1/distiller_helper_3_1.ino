 lcd.print("Distiller ");
 lcd.print(V);
 lcd.print("  ");
 delay(3000);
 Button = digitalRead(pin_Z);                    // Читаем нажата ли кнопка на джойстике
 Button = Button ^ 1;                            // Инвертируем сигнал нажатия кнопки джойстика 
